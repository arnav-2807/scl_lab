def fuzzy_composition(R, S):
    result = []
    for i in range(len(R)):
        row = []
        for j in range(len(S[0])):
            val = 0
            for k in range(len(S)):
                val = max(val, min(R[i][k], S[k][j]))
            row.append(val)
        result.append(row)
    return result

R = [[0.2, 0.5], [0.8, 0.3]]
S = [[0.6, 0.1], [0.4, 0.7]]

print(fuzzy_composition(R, S))
