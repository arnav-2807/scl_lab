dist = [[0,2,3],[2,0,4],[3,4,0]]
soil = [[1,1,1],[1,1,1],[1,1,1]]
path = [0]
while len(path) < 3:
    cur = path[-1]
    best = -1
    next_node = -1
    for j in range(3):
        if j not in path:
            val = 1 / (soil[cur][j] * dist[cur][j])
            if val > best:
                best = val
                next_node = j
    path.append(next_node)
    soil[cur][next_node] *= 0.9
print("Path:", path)
